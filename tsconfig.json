{
  "compilerOptions": {
    "target": "ES6",
    "module": "ES6",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "declaration": true,
    "outDir": "./dist/lib/es6",
    "moduleResolution": "node",
    "allowJs": false,
    "isolatedModules": true
    // https://github.com/evanw/esbuild/issues/314
  },
  "include": [
    "src/**/*"
  ]
}
